---
import Layout from "@layouts/es/Layout.astro";
import { SITE_DESCRIPTION_ES, SITE_URL } from "@lib/constants";
import Tabs from "@components/ui/Tabs.astro";
import { Image } from "astro:assets";
---

<Layout
    title={"Rafa Canosa Links"}
    description={SITE_DESCRIPTION_ES}
    canonical={SITE_URL}
>
    <main class="h-dvh text-center items-center flex flex-col gap-8">
        <Image
            class="rounded-xl shadow-sm hover:shadow-accent hover:shadow-lg hover:transition"
            src="/avatar.avif"
            alt="Rafa Canosa foto"
            width={150}
            height={150}
        />
        <h1 class="mb-8 text-4xl">All my Links</h1>
        <Tabs />
    </main>
</Layout>
